<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.bid2buy.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_navigation_home_to_listingDetailsFragment"
            app:destination="@+id/listingDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_listings"
        android:name="com.example.bid2buy.ui.myListings.MyListingsFragment"
        android:label="@string/title_listings"
        tools:layout="@layout/fragment_my_listings">
        <action
            android:id="@+id/action_navigation_listings_to_listingDetailsFragment"
            app:destination="@+id/listingDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.example.bid2buy.ui.notifications.NotificationsFragment"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.bid2buy.ui.profile.ProfileFragment"
        android:label="@string/title_profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/navigation_add"
        android:name="com.example.bid2buy.ui.add.CreateListingFragment"
        android:label="@string/title_add"
        tools:layout="@layout/fragment_create_listing" />

    <fragment
        android:id="@+id/listingDetailsFragment"
        android:name="com.example.bid2buy.ui.details.ListingDetailsFragment"
        android:label="Listing Details"
        tools:layout="@layout/fragment_listing_details">
        <argument
            android:name="listingId"
            app:argType="string" />
        <action
            android:id="@+id/action_listingDetailsFragment_to_editListingFragment"
            app:destination="@+id/editListingFragment" />
    </fragment>

    <fragment
        android:id="@+id/editListingFragment"
        android:name="com.example.bid2buy.ui.details.EditListingFragment"
        android:label="Edit Listing"
        tools:layout="@layout/fragment_edit_listing">
        <argument
            android:name="listingId"
            app:argType="string" />
    </fragment>
</navigation>